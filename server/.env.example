# ─── 数据库 ───
# 开发: SQLite 本地文件
DATABASE_URL="file:./data/dev.db"
# 生产: PostgreSQL（推荐）
# DATABASE_URL="postgresql://user:pass@localhost:5432/today_ok"

# ─── 服务器 ───
PORT=3000
NODE_ENV="development"

# ─── JWT 认证 ───
JWT_SECRET="dev-secret-change-in-production-32chars!"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── 短信服务 ───
# mock = 日志打印（开发）| aliyun = 阿里云 SMS（生产）
SMS_PROVIDER="mock"
# SMS_PROVIDER="aliyun"
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME="今天还好"
ALIYUN_SMS_VERIFY_TEMPLATE_CODE=""
ALIYUN_SMS_ALERT_TEMPLATE_CODE=""

# ─── 语音电话服务 ───
# mock = 日志打印（开发）| aliyun = 阿里云语音通知（生产）
# 与 SMS 共用 ALIYUN_ACCESS_KEY_ID/SECRET
VOICE_PROVIDER="mock"
# VOICE_PROVIDER="aliyun"
ALIYUN_VOICE_ALERT_TEMPLATE_CODE=""

# ─── 推送服务 ───
# mock = 日志打印（开发）| apns = 真实 APNs 推送（生产）
APNS_PROVIDER="mock"
# APNS_PROVIDER="apns"
APNS_KEY_ID=""
APNS_TEAM_ID=""
APNS_KEY_PATH=""
APNS_BUNDLE_ID="com.todayok.app"

# ─── Apple IAP（NODE_ENV != development 时生效）───
APPLE_IAP_ISSUER_ID=""
APPLE_IAP_KEY_ID=""
APPLE_IAP_KEY_PATH=""
