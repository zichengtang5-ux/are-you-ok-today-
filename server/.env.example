# 今天还好 后端服务 - 环境变量

# 数据库 (开发环境使用 SQLite，生产用 PostgreSQL)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:pass@localhost:5432/today_ok"

# JWT
JWT_SECRET="dev-secret-change-in-production-32chars!"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# 短信服务 (开发环境 mock 模式无需配置)
SMS_PROVIDER="mock"
# SMS_PROVIDER="aliyun"
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME="今天还好"
ALIYUN_SMS_TEMPLATE_CODE=""

# APNs (S3 阶段)
APNS_KEY_ID=""
APNS_TEAM_ID=""
APNS_KEY_PATH=""
APNS_BUNDLE_ID="com.todayok.app"

# 服务
PORT=3000
NODE_ENV="development"
