# ─── 数据库 ───
# 开发 & 生产统一使用 PostgreSQL（SQLite 不支持多实例 / 行级锁，已弃用）
DATABASE_URL="postgresql://todayok:todayok@localhost:5432/today_ok?schema=public"

# ─── Redis（缓存 / 限流 / BullMQ 队列）───
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
# 调度分片：本实例负责的分片编号与总分片数（多实例部署时各实例配不同 SHARD_INDEX）
SCHEDULER_SHARD_INDEX=0
SCHEDULER_SHARD_TOTAL=1

# ─── 服务器 ───
PORT=3000
NODE_ENV="development"

# ─── JWT 认证 ───
JWT_SECRET="dev-secret-change-in-production-32chars!"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── 短信服务 ───
# mock = 日志打印（开发）| aliyun = 阿里云 SMS（生产）
SMS_PROVIDER="mock"
# SMS_PROVIDER="aliyun"
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME="今天还好"
ALIYUN_SMS_VERIFY_TEMPLATE_CODE=""
ALIYUN_SMS_ALERT_TEMPLATE_CODE=""

# ─── 语音电话服务 ───
# mock = 日志打印（开发）| aliyun = 阿里云语音通知（生产）
# 与 SMS 共用 ALIYUN_ACCESS_KEY_ID/SECRET
VOICE_PROVIDER="mock"
# VOICE_PROVIDER="aliyun"
ALIYUN_VOICE_ALERT_TEMPLATE_CODE=""

# ─── 推送服务 ───
# mock = 日志打印（开发）| apns = 真实 APNs 推送（生产）
APNS_PROVIDER="mock"
# APNS_PROVIDER="apns"
APNS_KEY_ID=""
APNS_TEAM_ID=""
APNS_KEY_PATH=""
APNS_BUNDLE_ID="com.todayok.app"

# ─── Apple IAP（NODE_ENV != development 时生效）───
APPLE_IAP_ISSUER_ID=""
APPLE_IAP_KEY_ID=""
APPLE_IAP_KEY_PATH=""
